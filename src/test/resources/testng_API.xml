<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Test Suite" parallel="false" verbose="1">
    <listeners>
        <listener class-name="core.RetryAnnotationTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="core.AllureTestListener"/>
    </listeners>
    <test name="Authentication API Tests">
        <classes>
            <class name="tests.api.AuthApiTests"/>
        </classes>
    </test>
    <test name="Notes API Tests">
        <classes>
            <class name="tests.api.NotesApiTests"/>
        </classes>
    </test>
</suite>
